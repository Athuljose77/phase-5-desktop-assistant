# Copy this file to .env and fill in your values
# DO NOT commit your .env file — it is gitignored

# Groq API key (free at https://console.groq.com)
ONLINE_API_KEY=your-groq-api-key-here

# Model names (defaults shown — change only if you want a different model)
ONLINE_MODEL=llama-3.1-8b-instant
OFFLINE_MODEL=qwen2.5:1.5b

# Gmail credentials for "send email" command (optional)
# Get an App Password at: myaccount.google.com/apppasswords
GMAIL_ADDRESS=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
